#include <stdio.h>
#include <string.h>

#define MAX 5

enum Status { WEAK = 1, OK, GOOD };

struct Student {
    int id;
    char name[50];
    float score;
    enum Status status;
};

/* ---------- INPUT FUNCTIONS ---------- */

void inputStudent(struct Student *s) {
    printf("Enter ID: ");
    scanf("%d", &s->id);

    printf("Enter Name: ");
    scanf("%s", s->name);

    printf("Enter Score: ");
    scanf("%f", &s->score);

    int st;
    printf("Select Status (1=WEAK, 2=OK, 3=GOOD): ");
    scanf("%d", &st);

    switch(st) {
        case 1: s->status = WEAK; break;
        case 2: s->status = OK; break;
        case 3: s->status = GOOD; break;
        default:
            printf("Invalid status -> set WEAK\n");
            s->status = WEAK;
    }
}

/* ---------- DISPLAY FUNCTIONS ---------- */

void printStudent(struct Student s) {
    printf("\n----------------------\n");
    printf("ID: %d\n", s.id);
    printf("Name: %s\n", s.name);
    printf("Score: %.2f\n", s.score);

    printf("Status: ");
    switch(s.status) {
        case WEAK: printf("WEAK\n"); break;
        case OK: printf("OK\n"); break;
        case GOOD: printf("GOOD\n"); break;
    }
}

void printAll(struct Student s[], int count) {

    if (count == 0) {
        printf("No students available.\n");
        return;
    }

    for (int i = 0; i < count; i++) {
        printStudent(s[i]);
    }
}

/* ---------- DELETE FUNCTION ---------- */

void deleteById(struct Student s[], int *count, int id) {

    for (int i = 0; i < *count; i++) {
        if (s[i].id == id) {

            for (int j = i; j < *count - 1; j++) {
                s[j] = s[j + 1];
            }

            (*count)--;
            printf("Deleted successfully.\n");
            return;
        }
    }

    printf("Student not found.\n");
}

/* ---------- MAIN ---------- */

int main() {

    struct Student students[MAX];
    int count = 0;

    int choice;
    int id;

    while (1) {

        printf("\n======= STUDENT SYSTEM =======\n");
        printf("1. Add Student\n");
        printf("2. Show All Students\n");
        printf("3. Delete Student\n");
        printf("4. Exit\n");
        printf("================================\n");
        printf("Choice: ");
        scanf("%d", &choice);

        switch(choice) {

            case 1:
                if (count >= MAX) {
                    printf("Max capacity reached!\n");
                    break;
                }

                inputStudent(&students[count]);
                count++;
                break;

            case 2:
                printAll(students, count);
                break;

            case 3:
                printf("Enter ID to delete: ");
                scanf("%d", &id);
                deleteById(students, &count, id);
                break;

            case 4:
                return 0;

            default:
                printf("Invalid option!\n");
        }
    }

    return 0;
}
