#include <stdio.h>
#include <string.h>

#define MAX 5

enum Status { WEAK = 1, OK, GOOD };

struct Student {
    int id;
    char name[50];
    float score;
    enum Status status;
};

void updateScore(struct Student *s) {
    float newScore;
    printf("Enter new score: ");
    scanf("%f", &newScore);
    s->score = newScore;
}

void updateName(struct Student *s) {
    printf("Enter new name: ");
    scanf("%s", s->name);
}

void updateStatus(struct Student *s) {
    int choice;
    printf("Select status (1=WEAK, 2=OK, 3=GOOD): ");
    scanf("%d", &choice);

    switch(choice) {
        case 1: s->status = WEAK; break;
        case 2: s->status = OK; break;
        case 3: s->status = GOOD; break;
        default: printf("Invalid status\n");
    }
}

void deleteStudent(struct Student s[], int *count, int id) {

    int found = 0;

    for (int i = 0; i < *count; i++) {
        if (s[i].id == id) {

            found = 1;

            for (int j = i; j < *count - 1; j++) {
                s[j] = s[j + 1];
            }

            (*count)--;
            printf("Student deleted successfully\n");
            break;
        }
    }

    if (!found) {
        printf("Student not found\n");
    }
}

int main() {

    struct Student students[MAX];
    int count = 0;

    int choice;
    int idSearch;
    int found;

    while (1) {

        printf("\n--- MENU ---\n");
        printf("1. Add student\n");
        printf("2. Show students\n");
        printf("3. Update student\n");
        printf("4. Delete student\n");
        printf("5. Exit\n");
        printf("Choice: ");
        scanf("%d", &choice);

        switch(choice) {

            case 1:

                if (count >= MAX) {
                    printf("Max limit reached!\n");
                    break;
                }

                printf("Enter ID: ");
                scanf("%d", &students[count].id);

                printf("Enter Name: ");
                scanf("%s", students[count].name);

                printf("Enter Score: ");
                scanf("%f", &students[count].score);

                printf("Select Status (1=WEAK, 2=OK, 3=GOOD): ");
                scanf("%d", &choice);

                switch(choice) {
                    case 1: students[count].status = WEAK; break;
                    case 2: students[count].status = OK; break;
                    case 3: students[count].status = GOOD; break;
                    default:
                        printf("Invalid status, set WEAK\n");
                        students[count].status = WEAK;
                }

                count++;
                break;

            case 2:

                if (count == 0) {
                    printf("No students yet.\n");
                    break;
                }

                for (int i = 0; i < count; i++) {
                    printf("\nID: %d\n", students[i].id);
                    printf("Name: %s\n", students[i].name);
                    printf("Score: %.2f\n", students[i].score);

                    printf("Status: ");
                    switch(students[i].status) {
                        case WEAK: printf("WEAK\n"); break;
                        case OK: printf("OK\n"); break;
                        case GOOD: printf("GOOD\n"); break;
                    }
                }
                break;

            case 3:

                if (count == 0) {
                    printf("No students to update.\n");
                    break;
                }

                printf("Enter student ID: ");
                scanf("%d", &idSearch);

                found = 0;

                for (int i = 0; i < count; i++) {
                    if (students[i].id == idSearch) {

                        found = 1;

                        printf("1. Update Name\n");
                        printf("2. Update Score\n");
                        printf("3. Update Status\n");
                        scanf("%d", &choice);

                        if (choice == 1) updateName(&students[i]);
                        else if (choice == 2) updateScore(&students[i]);
                        else if (choice == 3) updateStatus(&students[i]);
                        else printf("Invalid option\n");

                        break;
                    }
                }

                if (!found) {
                    printf("Student not found\n");
                }

                break;

            case 4:

                if (count == 0) {
                    printf("No students to delete\n");
                    break;
                }

                printf("Enter student ID to delete: ");
                scanf("%d", &idSearch);

                deleteStudent(students, &count, idSearch);

                break;

            case 5:
                return 0;

            default:
                printf("Invalid menu option!\n");
        }
    }

    return 0;
}
