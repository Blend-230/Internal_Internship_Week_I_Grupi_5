#include <stdio.h>

int main() {
    int age, option;
    char initial;
    double points;

    // Input
    printf("Enter age: ");
    scanf("%d", &age);

    printf("Enter initial: ");
    scanf(" %c", &initial);

    printf("Enter points: ");
    scanf("%lf", &points);

    printf("Choose workshop (1-3): ");
    scanf("%d", &option);

    // Age check
    printf("\n--- Registration Status ---\n");
    if (age >= 16 && age <= 25) {
        printf("Age status: Eligible\n");
    } else {
        printf("Age status: Not eligible\n");
    }

    // Points classification
    printf("Performance: ");
    if (points < 50) {
        printf("Needs more practice\n");
    } else if (points < 80) {
        printf("Ready to continue\n");
    } else {
        printf("Ready for challenge\n");
    }

    // Workshop selection
    printf("Workshop: ");
    switch(option) {
        case 1:
            printf("Programming Basics\n");
            break;
        case 2:
            printf("Web Development\n");
            break;
        case 3:
            printf("Cybersecurity\n");
            break;
        default:
            printf("Invalid option\n");
    }

    // Final summary
    printf("\n--- Summary ---\n");
    printf("Age: %d\n", age);
    printf("Initial: %c\n", initial);
    printf("Points: %.2lf\n", points);
    printf("Selected option: %d\n", option);

    return 0;
}
