#include <stdio.h>

int main() {
    int start, end;
    int count3 = 0, sum3 = 0;
    int count5 = 0, sum5 = 0;

    printf("Shkruaj fillimin e intervalit: ");
    scanf("%d", &start);

    printf("Shkruaj fundin e intervalit: ");
    scanf("%d", &end);

    if (start > end) {
        printf("Interval i pavlefshem!\n");
        return 0;
    }

    for (int i = start; i <= end; i++) {
        if (i % 3 == 0) {
            count3++;
            sum3 += i;
        } 
        else if (i % 5 == 0) {
            count5++;
            sum5 += i;
        }
    }

    printf("\n--- Rezultati ---\n");
    printf("Intervali: [%d - %d]\n", start, end);

    printf("\nPjestohen me 3:\n");
    printf("Numri: %d\n", count3);
    printf("Shuma: %d\n", sum3);

    printf("\nPjestohen me 5 (jo me 3):\n");
    printf("Numri: %d\n", count5);
    printf("Shuma: %d\n", sum5);

    if (sum3 > sum5) {
        printf("\nMe e madhe eshte shuma e 3-shave\n");
    } else if (sum5 > sum3) {
        printf("\nMe e madhe eshte shuma e 5-shave\n");
    } else {
        printf("\nShumat jane te barabarta\n");
    }

    return 0;
}
